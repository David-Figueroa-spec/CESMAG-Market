@model List<Tiendavirtual_Figueroa.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Usuarios registrados</h4>
    <a asp-action="Create" class="btn btn-primary">+ Nuevo usuario</a>
</div>

<div class="table-responsive">
<table class="table table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Facultad</th>
            <th>Rol</th>
            <th>Celular</th>
            <th>Calificación</th>
            <th>Validado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Nombre</td>
                <td>@u.Correo</td>
                <td>@u.Facultad</td>
                <td><span class="badge @(u.Rol == "admin" ? "bg-dark" : "bg-secondary")">@u.Rol</span></td>
                <td>@u.Celular</td>
                <td>★ @u.Calificacion.ToString("F1")</td>
                <td>
                    <span class="badge @(u.Validado ? "bg-success" : "bg-warning text-dark")">
                        @(u.Validado ? "Validado" : "Pendiente")
                    </span>
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary">Editar</a>

                    <a asp-action="ToggleValidado" asp-route-id="@u.Id"
                       class="btn btn-sm @(u.Validado ? "btn-outline-warning" : "btn-outline-success")"
                       onclick="return confirm('¿Cambiar estado de validación?')">
                        @(u.Validado ? "Invalidar" : "Validar")
                    </a>

                    <a asp-action="Delete" asp-route-id="@u.Id"
                       class="btn btn-sm btn-outline-danger"
                       onclick="return confirm('¿Eliminar usuario @u.Nombre?')">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</div>
